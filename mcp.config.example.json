{
  "mcpServers": {
    "echotik-lite": {
      "command": "node",
      "args": [
        "/absolute/path/to/echotik-api-skills/mcp/server.mjs"
      ],
      "env": {
        "ECHOTIK_USERNAME": "your_username",
        "ECHOTIK_PASSWORD": "your_password",
        "ECHOTIK_AUTH_HEADER": "",
        "ECHOTIK_BASE_URL": "https://open.echotik.live"
      }
    }
  }
}
